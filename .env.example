# Application
APP_NAME=Prisma Factsheet API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database (SQLite = no install needed; PostgreSQL = production/Docker)
DATABASE_URL=sqlite:///./data/prisma_factsheet.db
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/prisma_factsheet
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Scheduler (cron-style, UTC)
ETL_CRON_HOUR=6
ETL_CRON_MINUTE=0
SCHEDULER_ENABLED=true

# Logging
LOG_LEVEL=INFO

# ETL
YFINANCE_LOOKBACK_YEARS=5
RISK_FREE_RATE=0.04

# Fetch live yfinance data when seeding (slow; needs internet)
RUN_ETL_ON_SEED=false
